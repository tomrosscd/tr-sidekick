{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/collections/[slug]",
      "regex": "^/collections/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/collections/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/prompts/[slug]",
      "regex": "^/prompts/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/prompts/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/skills/[slug]",
      "regex": "^/skills/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/skills/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/admin/collections",
      "regex": "^/admin/collections(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/collections(?:/)?$"
    },
    {
      "page": "/admin/prompts",
      "regex": "^/admin/prompts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/prompts(?:/)?$"
    },
    {
      "page": "/admin/skill-submissions",
      "regex": "^/admin/skill\\-submissions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/skill\\-submissions(?:/)?$"
    },
    {
      "page": "/admin/skills",
      "regex": "^/admin/skills(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/skills(?:/)?$"
    },
    {
      "page": "/admin/submissions",
      "regex": "^/admin/submissions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/submissions(?:/)?$"
    },
    {
      "page": "/auth/callback",
      "regex": "^/auth/callback(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/auth/callback(?:/)?$"
    },
    {
      "page": "/collections",
      "regex": "^/collections(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/collections(?:/)?$"
    },
    {
      "page": "/design-system",
      "regex": "^/design\\-system(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/design\\-system(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/skills",
      "regex": "^/skills(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/skills(?:/)?$"
    },
    {
      "page": "/skills/submit",
      "regex": "^/skills/submit(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/skills/submit(?:/)?$"
    },
    {
      "page": "/submit",
      "regex": "^/submit(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/submit(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}