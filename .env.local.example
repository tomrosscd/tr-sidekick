# ──────────────────────────────────────────────
# Supabase (required)
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ──────────────────────────────────────────────
# Auth & access rules (required)
# ──────────────────────────────────────────────
# Email domain that gets "internal" access to all prompts
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=convertdigital.com.au

# Email address granted full admin access
NEXT_PUBLIC_ADMIN_EMAIL=tom@convertdigital.com.au

# ──────────────────────────────────────────────
# App URL (required for OAuth redirect)
# ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ──────────────────────────────────────────────
# GA4 analytics (optional)
# ──────────────────────────────────────────────
# Leave blank to disable GA4 tracking entirely
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ──────────────────────────────────────────────
# Email notifications via Resend (optional)
# ──────────────────────────────────────────────
# Leave blank to skip email notifications on prompt submissions
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PROMPT_SUBMISSION_NOTIFY_EMAIL=tom@convertdigital.com.au
